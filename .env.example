# Which flight data provider to use.
#   mock — simulated flights, zero config, shows the demo banner (default)
#   fr24 — live Flightradar24 data, requires FR24_API_TOKEN
FLIGHT_PROVIDER=mock

# Required when FLIGHT_PROVIDER=fr24.
# Get a key at https://fr24api.flightradar24.com — the $9/mo Explorer tier
# comfortably covers personal use.
FR24_API_TOKEN=
